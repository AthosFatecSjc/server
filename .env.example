# Configurações gerais do Django
DEBUG=True
ALLOWED_HOSTS=<allowed-hosts-vem-aqui>
CRON_BUSCAR_DADOS=<frequencia-cron-vem-aqui>
SECRET_KEY=<django-key-for-github-actions>
SENTRY_DSN=<dsn-do-sentry-vem-aqui>

# Configurações do banco PostgreSQL
DB_OLTP_NAME=<nome-do-banco-vem-aqui>
DB_OLTP_USER=<usuario-do-banco-vem-aqui>
DB_OLTP_PASSWORD=<senha-do-usuario-do-banco-aqui>
DB_OLTP_HOST=localhost
DB_OLTP_PORT=<porta-do-banco-vem-aqui>

# Configurações do banco PostgreSQL
DB_OLAP_NAME=<nome-do-banco-vem-aqui>
DB_OLAP_USER=<usuario-do-banco-vem-aqui>
DB_OLAP_PASSWORD=<senha-do-usuario-do-banco-aqui>
DB_OLAP_HOST=localhost
DB_OLAP_PORT=5432

# Configurações do Jira
JIRA_BASE_URL=<url-do-jira-vem-aqui>
JIRA_USER=<usuario-do-jira-vem-aqui>
JIRA_TOKEN=<token-do-jira-vem-aqui>
